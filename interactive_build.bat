@echo off
title نظام البناء التفاعلي

:MENU
cls
echo ===========================
echo    نظام البناء التفاعلي
echo ===========================
echo 1. بناء المشروع
echo 2. تنظيف البن��ء
echo 3. الخروج
echo ===========================
set /p choice="اختر خيار (1-3): "

if "%choice%"=="1" (
    echo بناء المشروع...
    REM هنا يمكن إضافة الأمر الفعلي للبناء
    echo تم البناء بنجاح.
) else if "%choice%"=="2" (
    echo تنظيف البناء...
    REM هنا يمكن إضافة الأمر الفعلي لتنظيف البناء
    echo تم تنظيف البناء.
) else if "%choice%"=="3" (
    echo الخروج من البرنامج...
    exit
) else (
    echo اختيار غير صحيح. برجاء المحاولة مرة أخرى.
    pause
    goto MENU
)

pause
goto MENU
